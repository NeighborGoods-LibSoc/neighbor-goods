# Database type: 'mongodb' or 'postgres'
DATABASE_TYPE=mongodb
# Database connection string (must match DATABASE_TYPE)
# For MongoDB: mongodb://mongo:27017/neighbor-goods
# For Postgres: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URI=mongodb://mongo:27017/neighbor-goods

# Postgres credentials (used by docker-compose to provision the postgres container)
POSTGRES_USER=neighborgoods
POSTGRES_PASSWORD=neighborgoods
POSTGRES_DB=neighbor-goods

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Environment mode (production or development)
NG_ENV=production

# SMTP Server setup. Used for sending password resets
SMTP_SERVER=smtp.gmail.com
SMTP_USER=example@gmail.com
SMTP_PASSWORD=app_password
